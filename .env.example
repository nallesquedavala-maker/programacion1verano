# Copia este archivo como ".env" y llena los valores de tu proyecto de Supabase.
# Los encuentras en: Supabase → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY

# Dominio del correo institucional permitido para registrarse.
# Déjalo vacío para permitir cualquier correo.
VITE_DOMINIO_INSTITUCIONAL=
